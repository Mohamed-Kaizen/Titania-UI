{
	"name": "titania-ui",
	"version": "0.1.0",
	"packageManager": "pnpm@7.22.0",
	"description": "Behold Titania UI Project",
	"author": "Mohamed Nesredin<https://github.com/Mohamed-Kaizen>",
	"license": "MIT",
	"homepage": "https://github.com/Mohamed-Kaizen/titania-ui#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Mohamed-Kaizen/titania-ui.git"
	},
	"bugs": {
		"url": "https://github.com/Mohamed-Kaizen/titania-ui/issues"
	},
	"private": true,
	"scripts": {
		"build": "vite build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"commit": "cz commit",
		"dev": "vite dev",
		"lint": "prettier --plugin-search-dir . --check . && eslint .",
		"preview": "vite preview",
		"format": "prettier --plugin-search-dir . --write ."
	},
	"devDependencies": {
		"@iconify/json": "^2.2.36",
		"@sveltejs/adapter-auto": "^2.0.0",
		"@sveltejs/kit": "^1.12.0",
		"@trivago/prettier-plugin-sort-imports": "^4.1.1",
		"@typescript-eslint/eslint-plugin": "^5.55.0",
		"@typescript-eslint/parser": "^5.55.0",
		"@unocss/reset": "^0.50.6",
		"eslint": "^8.36.0",
		"eslint-config-prettier": "^8.7.0",
		"eslint-plugin-svelte3": "^4.0.0",
		"eslint-plugin-tsdoc": "^0.2.17",
		"prettier": "^2.8.0",
		"prettier-plugin-svelte": "^2.9.0",
		"svelte": "^3.57.0",
		"svelte-check": "^3.1.4",
		"@sveu/actions": "^0.5.0",
		"@sveu/shared": "^0.9.0",
		"@sveu/browser": "^0.20.0",
		"@sveu/extend": "^0.4.0",
		"tslib": "^2.5.0",
		"typescript": "^4.9.3",
		"unocss": "^0.50.6",
		"unplugin-auto-import": "^0.15.1",
		"unplugin-svelte-components": "^0.2.6",
		"vite": "^4.2.0"
	},
	"type": "module"
}
